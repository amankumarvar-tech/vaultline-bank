# Rename this file to .env before running the server

# MongoDB connection string (use MongoDB Atlas free tier, or local mongodb://localhost:27017/vaultline)
MONGO_URI=mongodb://localhost:27017/vaultline

# Server port
PORT=5000

# JWT secret — change this to a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_key_before_deploying
JWT_EXPIRES_IN=1d

# Admin bootstrap credentials (used only by the seed:admin script)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@12345

# Frontend origin allowed to call this API (CORS)
CLIENT_ORIGIN=http://localhost:5173
